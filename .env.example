# ============================================
# CREOTEC Dashboard - Plantilla de variables
# Copia este archivo a .env.local y rellena los valores del JSON de Google Cloud.
# ============================================

# Campo "client_email" del JSON de la Cuenta de Servicio
GOOGLE_CLIENT_EMAIL=tu-cuenta@tu-proyecto.iam.gserviceaccount.com

# Campo "private_key" del JSON. Debe ir ENTRE COMILLAS y en UNA sola línea,
# conservando los "\n" tal cual aparecen en el JSON.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# El ID está en la URL del Spreadsheet:
# https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
SPREADSHEET_ID=tu_spreadsheet_id
